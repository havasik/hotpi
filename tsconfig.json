{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@havasik/ai": ["./packages/ai/src/index.ts"],
			"@havasik/ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@havasik/ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@havasik/ai/dist/*": ["./packages/ai/src/*"],
			"@havasik/agent-core": ["./packages/agent/src/index.ts"],
			"@havasik/agent-core/*": ["./packages/agent/src/*"],
			"@havasik/hotpi": ["./packages/coding-agent/src/index.ts"],
			"@havasik/hotpi/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@havasik/hotpi/*": ["./packages/coding-agent/src/*"],
			"@sinclair/typebox": ["./node_modules/@sinclair/typebox"],
			"@havasik/mom": ["./packages/mom/src/index.ts"],
			"@havasik/mom/*": ["./packages/mom/src/*"],
			"@havasik/pods": ["./packages/pods/src/index.ts"],
			"@havasik/pods/*": ["./packages/pods/src/*"],
			"@havasik/tui": ["./packages/tui/src/index.ts"],
			"@havasik/tui/*": ["./packages/tui/src/*"],
			"@havasik/web-ui": ["./packages/web-ui/src/index.ts"],
			"@havasik/web-ui/*": ["./packages/web-ui/src/*"],
			"@mariozechner/pi-agent-old": ["./packages/agent-old/src/index.ts"],
			"@mariozechner/pi-agent-old/*": ["./packages/agent-old/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
